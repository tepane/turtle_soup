rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.uid in ["YOUR_ADMIN_UID"];
    }

    function isValidProblem() {
      return request.resource.data.keys().hasOnly([
          "title",
          "prompt",
          "answer",
          "difficulty",
          "creativity",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.prompt is string
        && request.resource.data.prompt.size() > 0
        && request.resource.data.prompt.size() <= 3000
        && request.resource.data.answer is string
        && request.resource.data.answer.size() > 0
        && request.resource.data.answer.size() <= 3000
        && request.resource.data.difficulty is int
        && request.resource.data.difficulty >= 1
        && request.resource.data.difficulty <= 5
        && request.resource.data.creativity is int
        && request.resource.data.creativity >= 1
        && request.resource.data.creativity <= 5
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    match /problems/{problemId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProblem();
      allow delete: if isAdmin();
    }
  }
}
